# 複製為 secret.yaml 並填入真實值（勿提交版控）：
#   Copy-Item config/secret.yaml.example config/secret.yaml
#
# 本機 Ollama 需先：ollama pull gemma4:e2b

ollama:
  base_url: http://localhost:11434/v1
  model: gemma4:e2b
  api_key: "" # 本機通常可留空；若端點要求可填占位字串

openai:
  api_base: https://api.openai.com/v1
  api_key: "" # sk-...

anthropic:
  api_base: https://api.anthropic.com
  api_version: "2023-06-01"
  api_key: "" # sk-ant-...

gemini:
  # Google AI Studio API Key（經 X-Goog-Api-Key Header 送出；與 gemini_pools 共用）
  api_base: https://generativelanguage.googleapis.com/v1beta
  api_key: "" # AIza...
  # 模型與 rpm/rpd 上限請在 aicentral.yaml 的 gemini_pools 區塊設定

mcp:
  linear:
    api_key: ""
